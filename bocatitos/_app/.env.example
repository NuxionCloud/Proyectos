# ──────────────────────────────────────────────
# Bocatitos · Variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# .env.local nunca se commitea (ver .gitignore).
# ──────────────────────────────────────────────

# URL pública del sitio (sin barra final)
PUBLIC_SITE_URL=http://localhost:4321

# WhatsApp del local (formato wa.me sin +)
PUBLIC_WHATSAPP=34641293669

# Instagram Basic Display API (opcional · si no, fallback a embeds estáticos)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=

# Google Maps embed key (opcional · ya usamos iframe sin key)
# PUBLIC_MAPS_API_KEY=

# Analytics (opcional · si lo activas, recuerda banner de cookies)
# PUBLIC_PLAUSIBLE_DOMAIN=bocatitos.es
