---
/**
 * Sobre nosotros · 7 cols texto + 5 cols imagen polaroid + stamp rotado.
 * Fondo --dark con ruido grano sutil.
 */
import Logo from '@components/ui/Logo.astro';

const aboutImage = 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=900&q=85&auto=format&fit=crop';
---

<section id="about" class="about relative bg-dark text-white py-2xl overflow-hidden scroll-mt-[120px]" aria-labelledby="about-h">
  <div class="noise-grain" aria-hidden="true"></div>

  <div class="wrap relative grid gap-xl md:gap-2xl md:grid-cols-12 items-center">
    <div class="md:col-span-7 order-2 md:order-1">
      <p class="font-condensed text-yellow text-lg tracking-widest uppercase mb-md inline-flex items-center gap-xs">
        <span aria-hidden="true" class="inline-block w-10 h-[2px] bg-yellow"></span>
        <span data-i18n="about.eyebrow">Sobre nosotros</span>
      </p>
      <h2 id="about-h" class="font-display uppercase leading-tight text-[clamp(2rem,5vw,3.5rem)]" data-i18n-html="man.title">
        Pequeño local, <em class="text-red not-italic">gran sabor.</em>
      </h2>

      <p class="mt-md text-base md:text-lg text-white/85 max-w-xl leading-relaxed" data-i18n-html="about.lead">
        Bocatitos es un local diminuto en plena <strong>Av. Sánchez Pizjuán</strong>, corazón del <strong>Distrito Macarena</strong> de Sevilla. Pan recién horneado, carne 100&nbsp;% vacuna que <em class="text-yellow not-italic">smasheamos en plancha</em>, salsas de la casa. Sin atajos, sin tonterías.
      </p>

      <p class="mt-md text-base text-white/75 max-w-xl leading-relaxed" data-i18n="about.body2">
        Abrimos en 2020 con una idea simple: traer el street food de barrio al norte de Sevilla. Desayunamos con tostadas de chapata y café de especialidad. Servimos tapas y montaditos al mediodía. Por la noche, smash burgers, bocatas en chapata y hot dogs — 17 recetas firmadas en 5 familias.
      </p>

      <ul class="mt-md grid grid-cols-1 sm:grid-cols-2 gap-2xs text-sm text-white/80 max-w-xl">
        <li class="flex items-start gap-xs"><span class="text-yellow font-display">✦</span> <span data-i18n="about.v1">Pan horneado a diario en el local</span></li>
        <li class="flex items-start gap-xs"><span class="text-yellow font-display">✦</span> <span data-i18n="about.v2">Carne 100% vacuna · smasheada al momento</span></li>
        <li class="flex items-start gap-xs"><span class="text-yellow font-display">✦</span> <span data-i18n="about.v3">Salsas caseras · receta propia</span></li>
        <li class="flex items-start gap-xs"><span class="text-yellow font-display">✦</span> <span data-i18n="about.v4">Take-away y delivery por WhatsApp</span></li>
        <li class="flex items-start gap-xs"><span class="text-yellow font-display">✦</span> <span data-i18n="about.v5">A 5 min del Sánchez-Pizjuán</span></li>
        <li class="flex items-start gap-xs"><span class="text-yellow font-display">✦</span> <span data-i18n="about.v6">Sin reservas · entras, pides, disfrutas</span></li>
      </ul>

      <a href="/carta" class="mt-lg inline-flex items-center gap-2xs border-2 border-yellow text-yellow px-md py-sm font-condensed text-base tracking-widest uppercase hover:bg-yellow hover:text-black transition-colors">
        <span data-i18n="about.cta">Conoce la carta</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="md:col-span-5 order-1 md:order-2 relative mx-auto">
      <div class="polaroid relative inline-block bg-cream p-xs pb-lg shadow-2xl">
        <img
          src={aboutImage}
          alt="Interior del local Bocatitos en Sevilla"
          width="480"
          height="600"
          loading="lazy"
          decoding="async"
          class="w-full max-w-[420px] aspect-[4/5] object-cover"
        />
        <span class="absolute bottom-2 left-0 right-0 text-center font-condensed text-black text-base tracking-widest uppercase">
          Bocatitos · 2020
        </span>
      </div>
      <!-- Logo oficial como sello rotado superpuesto -->
      <div class="absolute -top-md -right-md md:-top-lg md:-right-lg drop-shadow-2xl">
        <Logo size="lg" variant="circle" rotate={-8} alt="Logo Bocatitos" />
      </div>
    </div>
  </div>
</section>

<style>
  .polaroid {
    transform: rotate(-2deg);
    transition: transform var(--duration-base) var(--ease-out-expo);
  }
  .polaroid:hover {
    transform: rotate(0deg) scale(1.02);
  }
  .polaroid::before {
    content: '';
    position: absolute;
    top: 14px;
    left: 14px;
    width: 100%;
    height: 100%;
    background: var(--black);
    z-index: -1;
    transition: transform var(--duration-base) var(--ease-out-expo);
  }
  .polaroid:hover::before {
    transform: translate(8px, 8px);
  }

  @media (prefers-reduced-motion: reduce) {
    .polaroid, .polaroid:hover, .polaroid::before, .polaroid:hover::before {
      transform: none;
    }
  }
</style>
