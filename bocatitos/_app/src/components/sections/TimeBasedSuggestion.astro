---
/**
 * "¿Qué te apetece ahora?" · sugerencia según hora del cliente.
 *
 * Render SSR con valor de mediodía como fallback (mejor LCP).
 * En cliente, JS re-evalúa con la hora local real y reescribe.
 * Si JS desactivado, ve la versión SSR.
 */
import { getSuggestion } from '@lib/time';

const ssr = getSuggestion(13); // fallback tapa
---

<section class="tbs bg-black text-white py-2xl" aria-labelledby="tbs-h">
  <div class="wrap text-center">
    <p class="font-condensed text-yellow text-lg tracking-widest uppercase inline-flex items-center gap-xs">
      <span aria-hidden="true" class="inline-block w-10 h-[2px] bg-yellow"></span>
      <span data-i18n="tbs.eyebrow">Mira la hora</span>
    </p>
    <h2 id="tbs-h" class="font-display uppercase mt-2xs leading-[0.95] text-[clamp(2rem,5vw,3.5rem)]">
      <span data-i18n="tbs.h2_a">¿Qué te apetece</span> <span class="text-red" data-i18n="tbs.h2_b">ahora?</span>
    </h2>

    <div
      class="tbs-card mx-auto mt-lg max-w-2xl bg-darker border-2 border-white/10 p-lg md:p-xl"
      data-slot={ssr.slot}
      data-accent={ssr.accent}
    >
      <p class="font-condensed text-base tracking-widest uppercase text-white/50" data-tbs-clock>
        --:--
      </p>
      <h3 class="font-display uppercase mt-xs leading-tight text-[clamp(1.75rem,4vw,2.75rem)]" data-tbs-titulo>
        {ssr.titulo}
      </h3>
      <p class="mt-sm text-white/75 max-w-md mx-auto" data-tbs-desc>
        {ssr.desc}
      </p>
      <a
        href={ssr.href}
        class="mt-lg inline-flex items-center gap-2xs px-md py-sm font-condensed text-base tracking-widest uppercase border-2 transition-colors tbs-cta"
        data-tbs-href
        data-tbs-cta-text
      >
        <span>{ssr.cta}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  import { getSuggestion } from '@lib/time';

  const now = new Date();
  const hour = now.getHours();
  const min = now.getMinutes().toString().padStart(2, '0');
  const s = getSuggestion(hour);

  const card = document.querySelector<HTMLElement>('.tbs-card');
  const clock = document.querySelector<HTMLElement>('[data-tbs-clock]');
  const titulo = document.querySelector<HTMLElement>('[data-tbs-titulo]');
  const desc = document.querySelector<HTMLElement>('[data-tbs-desc]');
  const cta = document.querySelector<HTMLAnchorElement>('[data-tbs-href]');
  const ctaText = cta?.querySelector('span:first-child');

  if (card && clock && titulo && desc && cta && ctaText) {
    card.dataset.slot = s.slot;
    card.dataset.accent = s.accent;
    clock.textContent = `Ahora · ${hour.toString().padStart(2, '0')}:${min}`;
    titulo.textContent = s.titulo;
    desc.textContent = s.desc;
    cta.href = s.href;
    ctaText.textContent = s.cta;
  }
</script>

<style>
  .tbs-card[data-accent='desayuno'] { border-color: var(--cat-desayuno-soft); }
  .tbs-card[data-accent='desayuno'] .tbs-cta { border-color: var(--cat-desayuno-accent); color: var(--cat-desayuno-accent); }
  .tbs-card[data-accent='desayuno'] .tbs-cta:hover { background: var(--cat-desayuno-accent); color: var(--black); }

  .tbs-card[data-accent='tapas'] { border-color: var(--cat-tapas-soft); }
  .tbs-card[data-accent='tapas'] .tbs-cta { border-color: var(--cat-tapas-soft); color: var(--cat-tapas-soft); }
  .tbs-card[data-accent='tapas'] .tbs-cta:hover { background: var(--cat-tapas-soft); color: var(--black); }

  .tbs-card[data-accent='streetfood'] { border-color: var(--cat-streetfood); }
  .tbs-card[data-accent='streetfood'] .tbs-cta { border-color: var(--cat-streetfood); color: var(--cat-streetfood); }
  .tbs-card[data-accent='streetfood'] .tbs-cta:hover { background: var(--cat-streetfood); color: var(--black); }
</style>
