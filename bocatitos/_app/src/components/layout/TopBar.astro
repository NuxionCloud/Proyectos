---
/**
 * TopBar · banda roja superior con marquee promocional.
 * Cada promo se traduce vía data-i18n (i18n runtime cliente).
 */
import Marquee from './Marquee.astro';

const promos = [
  { key: 'topbar.promo1', text: 'Síguenos @bocatitosf' },
  { key: 'topbar.promo2', text: 'Abierto jueves a sábado hasta las 00:00' },
  { key: 'topbar.promo3', text: 'Desayunos solo en local' },
  { key: 'topbar.promo4', text: '17 recetas firmadas en Sevilla' },
];
---

<div class="topbar relative z-[60]">
  <Marquee
    items={promos}
    separator="★"
    speed="slowest"
    bg="bg-red"
    text="text-white"
    font="condensed"
    size="text-base md:text-lg"
    ariaLabel="Promociones y avisos"
  />
</div>
