{
  "name": "bocatitos-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Bocatitos · Sevilla — web oficial (Astro + Tailwind + GSAP)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/gen-sitemap.mjs",
    "build": "astro check && astro build",
    "preview": "astro preview --host",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,md,mdx,css,json}\"",
    "seed": "node scripts/seed-content.mjs",
    "sitemap": "node scripts/gen-sitemap.mjs",
    "logos": "node scripts/gen-logos.mjs",
    "hero-photos": "node scripts/gen-hero-photos.mjs",
    "ui-strings": "node scripts/gen-ui-strings.mjs",
    "og": "node scripts/gen-og.mjs",
    "verify-i18n": "node scripts/verify-i18n.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/tailwind": "^5.1.4",
    "astro": "^4.16.18",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
