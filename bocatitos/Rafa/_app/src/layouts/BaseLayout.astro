---
/**
 * BaseLayout — layout raíz para todas las páginas.
 * Maneja <head>: SEO, OG, favicon, fuentes, schema.org.
 * Inyecta skip-link + <slot /> para body.
 */
import '@styles/global.css';
import TopBar from '@components/layout/TopBar.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import WhatsAppFloat from '@components/layout/WhatsAppFloat.astro';
import DishI18nRuntime from '@components/layout/DishI18nRuntime.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  pageType?: 'website' | 'article' | 'restaurant';
  hideChrome?: boolean;
}

const {
  title,
  description = 'Bocatitos · El mejor sabor de Sevilla. Desayuno, tapas y street food en Av. Sánchez Pizjuán.',
  ogImage = '/og-default.jpg',
  canonical,
  pageType = 'website',
  hideChrome = false,
} = Astro.props;

// Homepage gets a full SEO title with keywords; otras páginas se concatenan al sufijo de marca.
const titleFull = title === 'Bocatitos'
  ? 'Bocatitos · Smash Burgers, Tapas y Street Food en Sevilla'
  : `${title} · Bocatitos · Sevilla`;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const ogImageAlt = 'Bocatitos · smash burgers y street food en Av. Sánchez Pizjuán, Sevilla';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="color-scheme" content="dark" />

    <!-- En recargas, ignora la posición guardada por el navegador y abre arriba del todo. -->
    <script is:inline>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      // Si la URL no trae #ancla, scroll instantáneo al top antes del primer paint.
      if (!window.location.hash) {
        window.scrollTo(0, 0);
      }
    </script>

    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Favicon · logo oficial Bocatitos (cada tamaño en su archivo, sin downscale del navegador) -->
    <link rel="icon" type="image/png" sizes="32x32" href="/logo-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/logo-192.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/logo-192.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={pageType === 'restaurant' ? 'restaurant.restaurant' : pageType} />
    <meta property="og:site_name" content="Bocatitos" />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Preconnect a CDNs externos · acelera primer paint -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Fonts (preload + non-blocking load) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bebas+Neue&family=Inter:wght@400;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bebas+Neue&family=Inter:wght@400;600;700;800&display=swap"
    />

    <!-- Schema.org Restaurant · enriquecido para rich snippets (horario, mapa, social) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Restaurant',
      '@id': 'https://bocatitos.es/#restaurant',
      name: 'Bocatitos',
      alternateName: 'Bocatitos Street Food',
      description,
      url: Astro.site?.toString(),
      telephone: '+34 641 29 36 69',
      priceRange: '€',
      image: [
        'https://bocatitos.es/og-default.jpg',
        'https://bocatitos.es/oficial/tito-gourmet.jpg',
        'https://bocatitos.es/oficial/bocakillo-1.jpg',
      ],
      servesCuisine: ['Spanish', 'Street Food', 'Burgers', 'Sandwiches'],
      paymentAccepted: ['Cash', 'Credit Card', 'Debit Card', 'Mobile Payment'],
      currenciesAccepted: 'EUR',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Av. Sánchez Pizjuán 6',
        addressLocality: 'Sevilla',
        addressRegion: 'Andalucía',
        postalCode: '41009',
        addressCountry: 'ES',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 37.4081349,
        longitude: -5.9881152,
      },
      hasMap: 'https://maps.google.com/?q=Av.+S%C3%A1nchez+Pizju%C3%A1n+6+Sevilla',
      sameAs: [
        'https://instagram.com/bocatitosf',
        'https://facebook.com/bocatitosf',
        'https://tiktok.com/@bocatitosf',
        'https://youtube.com/@bocatitosf',
        'https://open.spotify.com/user/31owrjaygxm6ebzz5bakeno7533a',
      ],
      openingHoursSpecification: [
        // Mañana / mediodía · lun-vie 08-16, sáb-dom 13-16
        { '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '08:00', closes: '16:00' },
        { '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Saturday', 'Sunday'],
          opens: '13:00', closes: '16:00' },
        // Noche / cena · mié-dom 19:30-23:30 (street food en plancha)
        { '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
          opens: '19:30', closes: '23:30' },
      ],
      acceptsReservations: false,
    })} />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link" data-i18n="header.skip">Saltar al contenido</a>

    {!hideChrome && <TopBar />}
    {!hideChrome && <Header />}

    <slot />

    {!hideChrome && <Footer />}
    {!hideChrome && <WhatsAppFloat />}

    <DishI18nRuntime />

    <slot name="after-body" />
  </body>
</html>
