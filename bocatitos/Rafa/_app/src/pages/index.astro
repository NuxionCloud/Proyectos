---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/hero/Hero.astro';
import ThreePillars from '@components/sections/ThreePillars.astro';
import About from '@components/sections/About.astro';
import TimeBasedSuggestion from '@components/sections/TimeBasedSuggestion.astro';
import Location from '@components/sections/Location.astro';
---

<BaseLayout
  title="Bocatitos"
  description="El mejor sabor de Sevilla. Desayuno, tapas y street food en Av. Sánchez Pizjuán. Pan recién horneado, carne smasheada en plancha y salsas de la casa."
  pageType="restaurant"
>
  <main id="main">
    <Hero />
    <ThreePillars />
    <About />
    <TimeBasedSuggestion />
    <Location />
  </main>
</BaseLayout>
