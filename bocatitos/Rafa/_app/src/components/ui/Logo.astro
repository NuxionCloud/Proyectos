---
/**
 * Logo · componente único para usar el logo oficial en cualquier sitio.
 *
 * Sirve <picture> con AVIF + WebP + PNG fallback, seleccionando el tamaño
 * más cercano al display real (DPR-aware con srcset 1x/2x). El navegador
 * elige el mejor formato y tamaño automáticamente — siempre nítido,
 * siempre el archivo más ligero compatible.
 *
 * Props:
 *  - size:    xs | sm | md | lg | xl | 2xl  → altura visual final
 *  - variant: default (rectangular) | circle (recortado con borde)
 *  - rotate:  grados de rotación (para sellos)
 *  - eager:   carga inmediata (Header, hero)
 *  - alt:     texto alternativo
 */
export interface Props {
  size?: 'xs' | 'sm' | 'lg' | 'xl' | 'hero';
  variant?: 'default' | 'circle';
  rotate?: number;
  eager?: boolean;
  alt?: string;
  class?: string;
}

const {
  size = 'sm',
  variant = 'default',
  rotate = 0,
  eager = false,
  alt = 'Bocatitos',
  class: extraClass = '',
} = Astro.props;

// Mapa tamaño visual → tamaño base (1x) + tamaño alta densidad (2x para Retina).
// Cubre todos los DPR sin layout shift.
const profiles = {
  xs:   { base: 32,  retina: 64,  cssH: 'h-6',                       w: 22,  h: 24  }, // 24 px
  sm:   { base: 64,  retina: 128, cssH: 'h-10',                      w: 36,  h: 40  }, // 40 px
  lg:   { base: 128, retina: 256, cssH: 'h-20',                      w: 72,  h: 80  }, // 80 px
  xl:   { base: 256, retina: 512, cssH: 'h-28',                      w: 101, h: 112 }, // 112 px
  hero: { base: 512, retina: 512, cssH: 'h-36 md:h-48 lg:h-56',      w: 256, h: 280 }, // 144→224 px responsive
} as const;

const p = profiles[size];
const isCircle = variant === 'circle';
const transform = rotate ? `transform: rotate(${rotate}deg);` : '';
const wrapperClass = isCircle
  ? `inline-flex items-center justify-center bg-yellow rounded-full overflow-hidden border-[3px] border-black ${p.cssH} aspect-square ${extraClass}`
  : `inline-block ${extraClass}`;
const imgClass = isCircle ? 'w-full h-full object-contain p-1' : `${p.cssH} w-auto`;
---

<picture class={wrapperClass} style={transform}>
  <source
    type="image/avif"
    srcset={`/logo-${p.base}.avif 1x, /logo-${p.retina}.avif 2x`}
  />
  <source
    type="image/webp"
    srcset={`/logo-${p.base}.webp 1x, /logo-${p.retina}.webp 2x`}
  />
  <img
    src={`/logo-${p.base}.png`}
    srcset={`/logo-${p.base}.png 1x, /logo-${p.retina}.png 2x`}
    alt={alt}
    width={p.w}
    height={p.h}
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
    fetchpriority={eager ? 'high' : undefined}
    class={imgClass}
  />
</picture>
