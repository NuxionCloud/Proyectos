---
/**
 * LangSwitcher · selector custom con bandera + código.
 * 5 idiomas. Persiste en localStorage. Recarga el resto del UI vía evento.
 *
 * Banderas: SVG inline (sin dependencias, consistente entre OS — los emojis
 * de bandera no se renderizan como bandera en Windows).
 */
import { LOCALES, LOCALE_NAMES, DEFAULT_LOCALE } from '@i18n/ui';

// Banderas SVG simples y reconocibles a 24×16 px (ratio 3:2 estándar).
const FLAGS: Record<string, string> = {
  es: `<svg viewBox="0 0 30 20" width="24" height="16" aria-hidden="true">
    <rect width="30" height="5" fill="#AA151B"/>
    <rect y="5" width="30" height="10" fill="#F1BF00"/>
    <rect y="15" width="30" height="5" fill="#AA151B"/>
  </svg>`,
  en: `<svg viewBox="0 0 60 40" width="24" height="16" aria-hidden="true">
    <rect width="60" height="40" fill="#012169"/>
    <path d="M0,0 L60,40 M60,0 L0,40" stroke="#fff" stroke-width="6"/>
    <path d="M0,0 L60,40 M60,0 L0,40" stroke="#C8102E" stroke-width="3" clip-path="polygon(0 0, 50% 50%, 0 0)"/>
    <rect x="26" width="8" height="40" fill="#fff"/>
    <rect y="16" width="60" height="8" fill="#fff"/>
    <rect x="28" width="4" height="40" fill="#C8102E"/>
    <rect y="18" width="60" height="4" fill="#C8102E"/>
  </svg>`,
  fr: `<svg viewBox="0 0 30 20" width="24" height="16" aria-hidden="true">
    <rect width="10" height="20" fill="#0055A4"/>
    <rect x="10" width="10" height="20" fill="#fff"/>
    <rect x="20" width="10" height="20" fill="#EF4135"/>
  </svg>`,
  it: `<svg viewBox="0 0 30 20" width="24" height="16" aria-hidden="true">
    <rect width="10" height="20" fill="#009246"/>
    <rect x="10" width="10" height="20" fill="#fff"/>
    <rect x="20" width="10" height="20" fill="#CE2B37"/>
  </svg>`,
  de: `<svg viewBox="0 0 30 21" width="24" height="16" aria-hidden="true">
    <rect width="30" height="7" fill="#000"/>
    <rect y="7" width="30" height="7" fill="#DD0000"/>
    <rect y="14" width="30" height="7" fill="#FFCE00"/>
  </svg>`,
};
---

<div class="lang-switcher relative" data-lang-switcher>
  <button
    type="button"
    class="lang-btn inline-flex items-center gap-xs px-xs py-2xs border border-white/20 hover:border-yellow font-condensed text-sm tracking-widest uppercase text-white/85 hover:text-yellow transition-colors"
    aria-haspopup="listbox"
    aria-expanded="false"
    data-lang-trigger
  >
    <span class="lang-trigger-flag inline-flex items-center" data-lang-trigger-flag>
      {LOCALES.map((l) => (
        <span class="flag-slot" data-flag={l} set:html={FLAGS[l]} />
      ))}
    </span>
    <span data-lang-current>{DEFAULT_LOCALE.toUpperCase()}</span>
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
  </button>

  <ul
    class="lang-list absolute top-full right-0 mt-2xs bg-black border-2 border-yellow min-w-[170px] z-[150] hidden"
    role="listbox"
    aria-label="Selecciona idioma"
    data-lang-list
  >
    {
      LOCALES.map((l) => (
        <li role="option" data-lang={l} aria-selected={l === DEFAULT_LOCALE ? 'true' : 'false'}>
          <button
            type="button"
            class="lang-opt w-full text-left px-md py-xs font-condensed text-sm tracking-widest uppercase text-white hover:bg-yellow hover:text-black transition-colors flex items-center gap-xs"
          >
            <span class="inline-flex items-center" set:html={FLAGS[l]} />
            <span class="font-bold">{l.toUpperCase()}</span>
            <span class="text-xs text-white/60 ml-auto">{LOCALE_NAMES[l]}</span>
          </button>
        </li>
      ))
    }
  </ul>
</div>

<script>
  import { LOCALES, type Locale, DEFAULT_LOCALE } from '@i18n/ui';

  const STORAGE_KEY = 'bocatitos.lang';

  const root = document.documentElement;
  const trigger = document.querySelector<HTMLButtonElement>('[data-lang-trigger]');
  const list = document.querySelector<HTMLUListElement>('[data-lang-list]');
  const current = document.querySelector<HTMLElement>('[data-lang-current]');
  const options = document.querySelectorAll<HTMLLIElement>('[data-lang]');

  const getLocale = (): Locale => {
    const stored = localStorage.getItem(STORAGE_KEY) as Locale | null;
    if (stored && (LOCALES as readonly string[]).includes(stored)) return stored;
    return DEFAULT_LOCALE;
  };

  const setLocale = (l: Locale) => {
    localStorage.setItem(STORAGE_KEY, l);
    root.setAttribute('lang', l);
    root.dataset.lang = l;             // CSS usa html[data-lang=...] para mostrar la bandera activa
    if (current) current.textContent = l.toUpperCase();
    options.forEach((o) => {
      o.setAttribute('aria-selected', o.dataset.lang === l ? 'true' : 'false');
    });
    document.dispatchEvent(new CustomEvent('localechange', { detail: { locale: l } }));
  };

  // Estado inicial
  setLocale(getLocale());

  // Toggle dropdown
  const close = () => {
    list?.classList.add('hidden');
    trigger?.setAttribute('aria-expanded', 'false');
  };
  const open = () => {
    list?.classList.remove('hidden');
    trigger?.setAttribute('aria-expanded', 'true');
  };
  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    trigger.getAttribute('aria-expanded') === 'true' ? close() : open();
  });
  document.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

  // Selección
  options.forEach((opt) => {
    opt.querySelector('button')?.addEventListener('click', () => {
      setLocale(opt.dataset.lang as Locale);
      close();
    });
  });
</script>

<style>
  .lang-list { box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.7); }

  /* En el trigger renderizamos las 5 banderas y solo mostramos la del idioma activo */
  .lang-trigger-flag .flag-slot { display: none; }
  :global(html[data-lang="es"]) .lang-trigger-flag .flag-slot[data-flag="es"],
  :global(html[data-lang="en"]) .lang-trigger-flag .flag-slot[data-flag="en"],
  :global(html[data-lang="fr"]) .lang-trigger-flag .flag-slot[data-flag="fr"],
  :global(html[data-lang="it"]) .lang-trigger-flag .flag-slot[data-flag="it"],
  :global(html[data-lang="de"]) .lang-trigger-flag .flag-slot[data-flag="de"] {
    display: inline-flex;
  }
  /* Fallback: si por lo que sea no hay data-lang aún, mostramos la primera (ES) */
  :global(html:not([data-lang])) .lang-trigger-flag .flag-slot[data-flag="es"] {
    display: inline-flex;
  }

  /* Bordes finos para que las banderas blancas/amarillas no desaparezcan sobre el fondo negro */
  .lang-switcher svg {
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 2px;
    flex-shrink: 0;
  }
</style>
