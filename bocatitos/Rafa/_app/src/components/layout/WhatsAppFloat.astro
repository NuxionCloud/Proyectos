---
/**
 * Botón flotante de WhatsApp.
 * Visible siempre (continuo) en la esquina inferior derecha.
 * Aparece con un fade-in suave cuando carga la página (delay para
 * no chocar con la intro cinematográfica del hero · ~3.7 s).
 */
import { getEntry } from 'astro:content';

const local = (await getEntry('settings', 'local'))?.data;
const phone = local?.whatsapp ?? '34641293669';
const message = encodeURIComponent('Hola Bocatitos, quería hacer un pedido 🍔');
---

<a
  href={`https://wa.me/${phone}?text=${message}`}
  target="_blank"
  rel="noopener"
  class="wa-float fixed bottom-md right-md z-[150] inline-flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-whatsapp text-white shadow-lg hover:bg-whatsapp-dark hover:scale-105 transition-colors"
  aria-label="Contactar por WhatsApp"
>
  <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
    <path d="M20.5 3.5A11.5 11.5 0 0 0 3.6 19l-1.1 4 4.1-1.1A11.5 11.5 0 1 0 20.5 3.5ZM12 21.3a9.3 9.3 0 0 1-4.7-1.3l-.3-.2-3 .8.8-2.9-.2-.3a9.3 9.3 0 1 1 7.4 3.9Zm5.3-7c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.2-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.7.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.6-.5h-.5c-.2 0-.5.1-.7.3-.2.2-.9.9-.9 2.3 0 1.3.9 2.6 1.1 2.8.1.2 1.9 2.8 4.5 4 .6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2 0-.1-.3-.2-.6-.3Z"/>
  </svg>
  <span class="sr-only">WhatsApp Bocatitos</span>
</a>

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .wa-float {
    box-shadow: 0 12px 30px -8px rgba(37, 211, 102, 0.55);
    opacity: 0;
    transform: translateY(12px);
    animation: wa-fade-in 0.55s var(--ease-out-expo) 3.7s forwards;
  }
  @keyframes wa-fade-in {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-float {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
