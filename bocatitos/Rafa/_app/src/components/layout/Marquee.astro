---
/**
 * Marquee · banda horizontal en loop infinito.
 * Pausa al hover. Respeta prefers-reduced-motion (CSS global).
 *
 * Props:
 *  - items: array de strings a mostrar
 *  - separator: separador visual entre items (★ ✦ 🔥 ·)
 *  - speed: slow | normal | fast (15-40s)
 *  - bg: clase Tailwind del fondo
 *  - text: clase Tailwind del texto
 *  - font: display | condensed | body
 *  - size: clase Tailwind del tamaño
 *  - bordered: añade borde rojo superior+inferior
 */
type Item = string | { key: string; text: string };

export interface Props {
  items: Item[];
  separator?: string;
  speed?: 'slowest' | 'slow' | 'normal' | 'fast';
  bg?: string;
  text?: string;
  font?: 'display' | 'condensed' | 'body';
  size?: string;
  bordered?: boolean;
  ariaLabel?: string;
}

const {
  items,
  separator = '★',
  speed = 'normal',
  bg = 'bg-red',
  text = 'text-white',
  font = 'condensed',
  size = 'text-xl',
  bordered = false,
  ariaLabel = 'Información destacada',
} = Astro.props;

const fontClass = {
  display: 'font-display',
  condensed: 'font-condensed tracking-widest',
  body: 'font-body font-bold',
}[font];

const borderClass = bordered ? 'border-y-[3px] border-red' : '';
const trackItems = [...items, ...items, ...items, ...items];
---

<div
  class={`marquee-wrap ${bg} ${text} ${borderClass} relative overflow-hidden py-2xs select-none uppercase`}
  role="region"
  aria-label={ariaLabel}
>
  <div class="marquee" data-speed={speed} aria-hidden="true">
    {
      trackItems.map((item) => {
        const isObj = typeof item === 'object';
        const text = isObj ? item.text : item;
        const key  = isObj ? item.key  : undefined;
        return (
          <span class={`inline-flex items-center gap-md whitespace-nowrap px-md ${fontClass} ${size}`}>
            <span {...(key ? { 'data-i18n': key } : {})}>{text}</span>
            <span class="text-yellow opacity-80 text-base">{separator}</span>
          </span>
        );
      })
    }
  </div>
  <span class="sr-only">{items.map((i) => typeof i === 'object' ? i.text : i).join('. ')}</span>
</div>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
