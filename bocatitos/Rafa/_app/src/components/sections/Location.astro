---
/**
 * Location · info del local + mapa embed.
 *
 * El mapa se construye en runtime con la dirección de
 * `src/content/settings/local.json` → al cambiarla allí, el mapa se actualiza
 * automáticamente. No depende de claves de API ni de place_ids.
 *
 * Carga directa (no requiere click) pero con `loading="lazy"`: el iframe sólo
 * se monta cuando el usuario scroll-ea hasta él, no infla el initial load.
 */
import { getEntry } from 'astro:content';

const local = (await getEntry('settings', 'local'))?.data;

// Dirección completa para que Google centre exactamente sobre el local.
const fullAddress = [
  local?.direccion,
  local?.codigoPostal,
  local?.ciudad,
  local?.pais,
].filter(Boolean).join(', ');

const mapEmbedUrl = `https://www.google.com/maps?q=${encodeURIComponent(fullAddress)}&output=embed&hl=es&z=17`;
const mapLinkUrl = local?.mapaLink ?? `https://maps.google.com/?q=${encodeURIComponent(fullAddress)}`;
---

<section class="location bg-darker text-white py-2xl border-t border-white/10" aria-labelledby="loc-h">
  <div class="wrap grid gap-xl md:gap-2xl md:grid-cols-12 items-center">
    <div class="md:col-span-5">
      <p class="font-condensed text-yellow text-lg tracking-widest uppercase inline-flex items-center gap-xs">
        <span aria-hidden="true" class="inline-block w-10 h-[2px] bg-yellow"></span>
        <span data-i18n="loc.eyebrow">Visítanos</span>
      </p>
      <h2 id="loc-h" class="font-display uppercase mt-2xs leading-[0.95] text-[clamp(2rem,5vw,3.5rem)]" data-i18n="loc.h2">
        Pásate por el local.
      </h2>
      <p class="mt-md text-white/75 max-w-md" data-i18n="loc.body">
        En plena Avenida Sánchez Pizjuán, en el corazón del barrio Macarena.
      </p>

      <dl class="mt-lg grid gap-md font-condensed">
        <div>
          <dt class="text-yellow text-sm tracking-widest uppercase mb-2xs" data-i18n="loc.addr">Dirección</dt>
          <dd class="text-lg">{local?.direccion}<br />{local?.codigoPostal} {local?.ciudad}</dd>
        </div>
        <div>
          <dt class="text-yellow text-sm tracking-widest uppercase mb-2xs" data-i18n="loc.phone">Teléfono · WhatsApp</dt>
          <dd class="text-lg">
            <a href={`tel:${local?.telefono.replace(/\s/g, '')}`} class="hover:text-yellow transition-colors">{local?.telefono}</a>
          </dd>
        </div>
        <div>
          <dt class="text-yellow text-sm tracking-widest uppercase mb-2xs" data-i18n="loc.hours">Horario</dt>
          <dd>
            <ul class="text-sm space-y-2xs">
              {local && Object.entries(local.horario).map(([dia, horas]) => (
                <li>
                  <span class="text-white/50 capitalize" data-i18n={`day.${dia}`}>{dia}</span><span class="text-white/50">:</span>
                  <span class="text-white">{horas}</span>
                </li>
              ))}
            </ul>
          </dd>
        </div>
      </dl>

      <div class="mt-lg flex flex-wrap gap-xs">
        <a
          href={mapLinkUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2xs bg-yellow text-black px-md py-sm font-condensed text-base tracking-widest uppercase hover:bg-white transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-7-7-12a7 7 0 1 1 14 0c0 5-7 12-7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
          <span data-i18n="loc.map_cta">Cómo llegar</span>
        </a>
        <a
          href={`https://wa.me/${local?.whatsapp}`}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2xs border-2 border-white/90 text-white px-md py-sm font-condensed text-base tracking-widest uppercase hover:bg-white hover:text-black transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M20.5 3.5A11.5 11.5 0 0 0 3.6 19l-1.1 4 4.1-1.1A11.5 11.5 0 1 0 20.5 3.5Z"/></svg>
          <span>WhatsApp</span>
        </a>
      </div>
    </div>

    <div class="md:col-span-7">
      <div class="map-frame relative aspect-[5/4] md:aspect-[16/12] border-2 border-white/10 overflow-hidden bg-black">
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Ubicación Bocatitos · ${fullAddress}`}
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>
