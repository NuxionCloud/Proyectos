---
/**
 * Hero v5.3 · intro cinematográfica con aterrizaje exacto medido por JS.
 *
 * Coreografía (4.2 s total):
 *   1) Logo overlay aparece grande en el centro                            0.0–0.7 s
 *   2) Permanece anclado en el centro (respiro)                            0.7–2.1 s
 *   3) Se desliza despacio hacia el logo real del header                  2.1–4.0 s
 *   4) Fade-out final al aterrizar                                        3.6–4.2 s
 *   5) Eyebrow / H1 / pilares suben escalonados desde abajo               2.6–4.0 s
 *
 * La posición Y/X y el scale finales se MIDEN en runtime con
 * getBoundingClientRect() del logo del header, así caen exactos sin
 * importar la altura del TopBar, el padding del header o el viewport.
 *
 * Slideshow Ken Burns de 6 fotos oficiales (36 s).
 * prefers-reduced-motion: se salta toda la intro, todo aparece estático.
 */

const slides = [
  { base: '/oficial/tito-gourmet',         alt: 'TITO GOURMET · smash burger insignia de Bocatitos' },
  { base: '/oficial/tito-bb',              alt: 'TITO BB · smash burger con cerdo de Bocatitos' },
  { base: '/oficial/bocakillo-1',          alt: 'Bocakillo · bocata street food de Bocatitos' },
  { base: '/oficial/bocakillo-2',          alt: 'Bocakillo · variedad de bocatas de Bocatitos' },
  { base: '/oficial/bocakillo-3',          alt: 'Bocakillo · selección street food de Bocatitos' },
  { base: '/oficial/carta-personalizada',  alt: 'Carta personalizada de Bocatitos' },
];

const pillars = [
  { href: '/carta#desayuno', i18nName: 'pillar.1.title',  name: 'Desayuno',    i18nHours: 'pillar.1.hours', hours: '08–12h', accent: 'desayuno' },
  { href: '/carta#tapa',     i18nName: 'pillar.2.title',  name: 'Tapas',       i18nHours: 'pillar.2.hours', hours: '12–17h', accent: 'tapas' },
  { href: '/carta#smash',    i18nName: 'pillar.3.title',  name: 'Street Food', i18nHours: 'pillar.3.hours', hours: '19–00h', accent: 'streetfood' },
];
---

<!-- Fallback sin JS · crawlers básicos, Twitter Cards y usuarios con JS deshabilitado
     ven el contenido del hero estático en lugar de quedarse en blanco. -->
<noscript>
  <style>
    .hero-intro { display: none !important; }
    .eyebrow-chip,
    .hero-h1,
    .hero-pillars { opacity: 1 !important; transform: none !important; animation: none !important; }
    .header .logo { opacity: 1 !important; animation: none !important; }
    .hero-slide-1 { opacity: 1 !important; }
    .hero-slide-2, .hero-slide-3, .hero-slide-4, .hero-slide-5, .hero-slide-6 { display: none !important; }
  </style>
</noscript>

<!-- Logo overlay · intro cinematográfica (entra grande, aterriza en el header) -->
<div class="hero-intro" aria-hidden="true" data-hero-intro>
  <picture class="hero-intro-logo">
    <source type="image/avif" srcset="/logo-512.avif" />
    <source type="image/webp" srcset="/logo-512.webp" />
    <img src="/logo-512.png" alt="" width="512" height="512" fetchpriority="high" decoding="async" />
  </picture>
</div>

<section class="hero relative overflow-hidden text-white" aria-label="Bienvenida">
  <!-- Slideshow full-bleed -->
  <div class="hero-bg absolute inset-0 z-0" aria-hidden="true">
    {
      slides.map((slide, i) => (
        <picture class={`hero-slide hero-slide-${i + 1} absolute inset-0 w-full h-full`}>
          <source type="image/avif" srcset={`${slide.base}.avif`} />
          <source type="image/webp" srcset={`${slide.base}.webp`} />
          <img
            src={`${slide.base}.jpg`}
            alt=""
            width="1100"
            height="1100"
            fetchpriority={i === 0 ? 'high' : undefined}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            class="w-full h-full object-cover"
          />
        </picture>
      ))
    }
    <span class="hero-overlay absolute inset-0"></span>
  </div>

  <!-- Contenido · sube hacia el tercio superior -->
  <div class="hero-content relative z-10 mx-auto max-w-[1100px] px-md text-center flex flex-col items-center">
    <p class="eyebrow-chip inline-block bg-yellow text-black font-condensed text-base tracking-widest uppercase px-md py-2xs" data-i18n="hero.eyebrow">
      Sevilla · Desde el barrio
    </p>

    <h1 class="hero-h1 mt-md md:mt-lg font-display uppercase leading-[0.95] tracking-tight text-[clamp(1.85rem,7vw,5rem)]">
      <span data-i18n="hero.h1a">El</span>
      <span class="text-red" data-i18n="hero.h1b">mejor</span>
      <span data-i18n="hero.h1c">sabor</span>
      <span data-i18n="hero.h1d">de Sevilla.</span>
    </h1>

    <!-- Pilares · tira horizontal de 3 chips (CTA principal in-hero) -->
    <ul class="hero-pillars mt-lg grid grid-cols-3 gap-2xs sm:gap-xs w-full max-w-3xl" role="list">
      {
        pillars.map((p) => (
          <li>
            <a
              href={p.href}
              class={`hero-pillar hero-pillar--${p.accent} group flex flex-col items-center justify-center gap-2xs px-2xs sm:px-xs py-xs sm:py-sm bg-black/55 backdrop-blur-md transition-all h-full`}
            >
              <span class="hero-pillar-name font-display text-[13px] sm:text-base md:text-lg tracking-tight leading-tight uppercase text-center break-words" data-i18n={p.i18nName}>
                {p.name}
              </span>
              <span class="hero-pillar-hours font-condensed text-[10px] sm:text-xs tracking-widest uppercase text-white/75" data-i18n={p.i18nHours}>
                {p.hours}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  /* Orquesta la intro cinematográfica.
     · Overlay position:absolute en el documento (NO bloquea scroll).
     · Cuando el usuario scrollea, el overlay se sube con la página y queda
       fuera de vista — la animación sigue corriendo pero no es visible.
     · Skip total si la URL trae #hash (ej. /#about) — el usuario navegó a
       una sección, no quiere ver la intro otra vez. */

  const overlay = document.querySelector<HTMLElement>('[data-hero-intro]');
  const overlayLogo = overlay?.querySelector<HTMLElement>('.hero-intro-logo');
  const headerLogo = document.querySelector<HTMLElement>('header .logo picture');

  const measure = () => {
    if (!overlay || !overlayLogo || !headerLogo) return;
    const target = headerLogo.getBoundingClientRect();
    const start = overlayLogo.getBoundingClientRect();
    const dx = (target.left + target.width / 2) - (start.left + start.width / 2);
    const dy = (target.top + target.height / 2) - (start.top + start.height / 2);
    const scale = target.height / start.height;
    overlay.style.setProperty('--intro-dx', `${dx.toFixed(1)}px`);
    overlay.style.setProperty('--intro-dy', `${dy.toFixed(1)}px`);
    overlay.style.setProperty('--intro-scale', scale.toFixed(3));
  };

  const orchestrate = () => {
    if (!overlay || !overlayLogo || !headerLogo) {
      document.documentElement.setAttribute('data-hero-ready', '');
      return;
    }
    measure();
    document.documentElement.setAttribute('data-hero-ready', '');
    // Re-mide en resize (rotación móvil, redimensión de ventana).
    window.addEventListener('resize', measure, { passive: true });
  };

  const start = () => {
    // Skip total si hay hash: el usuario navegó a una sección, no quiere intro.
    if (window.location.hash) {
      document.documentElement.setAttribute('data-hero-skip', '');
      document.documentElement.setAttribute('data-hero-ready', '');
      return;
    }
    // Espera fuentes para geometría estable, luego mide y arranca.
    if (document.fonts?.ready) {
      document.fonts.ready.then(() => requestAnimationFrame(orchestrate));
    } else {
      requestAnimationFrame(orchestrate);
    }
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    start();
  }
</script>

<style>
  .hero {
    min-height: clamp(720px, 100vh, 1080px);
    background: var(--black);
    isolation: isolate;
    /* Contenido alineado al tercio superior (sin CTA abajo, sube más natural) */
    display: flex;
    align-items: flex-start;
    padding-top: clamp(6.5rem, 20vh, 13rem);
    padding-bottom: clamp(3rem, 8vh, 5rem);
  }

  /* ─── Intro overlay: logo grande → aterriza en el logo del header ─── */
  /* position:absolute en el documento (no fixed) → si el usuario scrollea,
     el overlay se va con la página y deja de verse. La animación sigue
     corriendo, pero confinada al primer viewport. Sin bloqueo de scroll. */
  .hero-intro {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 250;            /* por encima del header (100) y drawer (200) */
    pointer-events: none;
    display: grid;
    place-items: center;
  }
  .hero-intro-logo {
    display: block;
    width: clamp(200px, 38vw, 360px);
    aspect-ratio: 1 / 1;
    transform-origin: center center;
    filter: drop-shadow(0 16px 36px rgba(0, 0, 0, 0.75));
    opacity: 0;             /* hasta que JS dé la señal */
  }
  .hero-intro-logo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Sólo cuando JS midió y marcó la raíz como lista, arrancan las animaciones */
  :global(html[data-hero-ready]) .hero-intro-logo {
    animation: heroIntro 4.2s var(--ease-out-expo) forwards;
  }

  /* El destino se interpola desde variables que JS calcula con
     getBoundingClientRect() del logo real del header. Fallback aproximado por si JS falla. */
  @keyframes heroIntro {
    0%   { opacity: 0; transform: translate(0, 0) scale(0.85); }
    14%  { opacity: 1; transform: translate(0, 0) scale(1); }
    50%  { opacity: 1; transform: translate(0, 0) scale(1); }
    92%  { opacity: 0.55; }
    100% {
      opacity: 0;
      transform:
        translate(var(--intro-dx, -45vw), var(--intro-dy, -45vh))
        scale(var(--intro-scale, 0.14));
    }
  }

  /* ─── Slideshow con Ken Burns ─── */
  .hero-slide {
    opacity: 0;
    filter: brightness(0.5);
    transform-origin: center center;
    animation: heroSlideshow 36s infinite ease-in-out;
    will-change: opacity, transform;
  }
  .hero-slide-1 { animation-delay: 0s;  transform-origin: center center; }
  .hero-slide-2 { animation-delay: 6s;  transform-origin: 30% 60%; }
  .hero-slide-3 { animation-delay: 12s; transform-origin: 70% 40%; }
  .hero-slide-4 { animation-delay: 18s; transform-origin: 40% 70%; }
  .hero-slide-5 { animation-delay: 24s; transform-origin: 60% 30%; }
  .hero-slide-6 { animation-delay: 30s; transform-origin: 50% 80%; }

  @keyframes heroSlideshow {
    0%    { opacity: 0; transform: scale(1.05); }
    2.8%  { opacity: 1; }
    13.9% { opacity: 1; }
    16.7% { opacity: 0; transform: scale(1.14); }
    100%  { opacity: 0; transform: scale(1.14); }
  }

  .hero-overlay {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.30) 0%,
      rgba(0, 0, 0, 0.55) 50%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }

  .hero-h1 {
    text-shadow: 0 6px 28px rgba(0, 0, 0, 0.65);
    overflow-wrap: anywhere;        /* permite cortar palabras larguísimas si falta espacio */
    text-wrap: balance;             /* balancea líneas (Chrome/FF/Safari moderno) */
    hyphens: none;
    max-width: 100%;
  }
  .hero-h1 > span { margin-right: 0.18em; }
  .hero-h1 > span:last-child { margin-right: 0; }

  /* ─── Skip total de la intro · activado cuando la URL trae #hash ─── */
  /* (ej. /#about cuando se clica en "Sobre nosotros"). El overlay no se
     muestra, ni los delays escalonados se aplican: todo aparece estático. */
  :global(html[data-hero-skip]) .hero-intro { display: none !important; }
  :global(html[data-hero-skip]) .eyebrow-chip,
  :global(html[data-hero-skip]) .hero-h1,
  :global(html[data-hero-skip]) .hero-pillars {
    opacity: 1 !important;
    transform: none !important;
    animation: none !important;
  }
  :global(html[data-hero-skip] .header .logo) {
    opacity: 1 !important;
    animation: none !important;
  }

  /* ─── Pilares · color distintivo SIEMPRE visible + glow en hover ─── */
  .hero-pillar {
    border: 2px solid;
    will-change: transform, box-shadow;
  }
  .hero-pillar:hover {
    transform: translateY(-3px);
    background: rgba(0, 0, 0, 0.7);
    box-shadow: 0 8px 28px -8px rgba(var(--pillar-glow), 0.55);
  }
  /* Desayuno · verde campo */
  .hero-pillar--desayuno {
    --pillar-glow: 111, 168, 106;
    border-color: #6FA86A;
  }
  .hero-pillar--desayuno .hero-pillar-name { color: #8FC58A; }
  /* Tapas · terracota Sevilla */
  .hero-pillar--tapas {
    --pillar-glow: 232, 150, 120;
    border-color: #E89678;
  }
  .hero-pillar--tapas .hero-pillar-name { color: #F2B5A0; }
  /* Street Food · amarillo marca */
  .hero-pillar--streetfood {
    --pillar-glow: 255, 224, 19;
    border-color: var(--yellow);
  }
  .hero-pillar--streetfood .hero-pillar-name { color: var(--yellow); }

  @media (prefers-reduced-motion: reduce) {
    .hero-pillar:hover { transform: none; }
  }

  /* ─── Contenido del hero: aparece DESPUÉS de la intro, escalonado ─── */
  .eyebrow-chip,
  .hero-h1,
  .hero-pillars {
    opacity: 0;
    transform: translateY(32px);
  }
  :global(html[data-hero-ready]) .eyebrow-chip,
  :global(html[data-hero-ready]) .hero-h1,
  :global(html[data-hero-ready]) .hero-pillars {
    animation: hero-in 0.95s var(--ease-out-expo) forwards;
  }
  :global(html[data-hero-ready]) .eyebrow-chip  { animation-delay: 2.55s; }
  :global(html[data-hero-ready]) .hero-h1       { animation-delay: 2.85s; }
  :global(html[data-hero-ready]) .hero-pillars  { animation-delay: 3.20s; }

  @keyframes hero-in {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mientras corre la intro ocultamos el logo del header (handoff invisible) */
  :global(.header .logo) {
    opacity: 0;
  }
  :global(html[data-hero-ready] .header .logo) {
    animation: header-logo-in 0.45s ease 3.85s forwards;
  }
  @keyframes header-logo-in {
    to { opacity: 1; }
  }

  /* ─── Reduced motion: nada se mueve, todo aparece estático ─── */
  @media (prefers-reduced-motion: reduce) {
    .hero-intro { display: none; }

    .eyebrow-chip, .hero-h1, .hero-pillars {
      opacity: 1; transform: none; animation: none;
    }
    :global(.header .logo) { opacity: 1; animation: none; }

    .hero-slide { animation: none; transform: none; }
    .hero-slide-1 { opacity: 1; }
    .hero-slide-2,
    .hero-slide-3,
    .hero-slide-4,
    .hero-slide-5,
    .hero-slide-6 { display: none; }
  }
</style>
